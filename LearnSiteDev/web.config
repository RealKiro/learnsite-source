<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <appSettings>
    <add key="Homework" value="~/homework/" />
  </appSettings>
  <connectionStrings>
    <!-- 
      请将下面192.168.1.7更改为你的数据库服务器名称或IP地址，这段中的learnsite更改为你创建的数据库名称和Zhou!12345更改为你的数据库密码：
     -->
    <remove name="SqlServer" />
    <add name="SqlServer" providerName="System.Data.SqlClient" connectionString="Data Source=COMPUTER\SQLEXPRESS;Initial Catalog=learnsite;uid=sa;pwd=123456;" />
  </connectionStrings>
  <system.web>
    <compilation debug="false" />
    <authentication mode="Windows" />
    <sessionState mode="InProc" timeout="720" />
    <httpRuntime maxRequestLength="2048000" executionTimeout="300" enableVersionHeader="false" />
    <machineKey validation="3DES" />
  </system.web>
</configuration>